{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AirBricks Snap Points",
  "type":"object",
  "required": ["partId", "version", "unit", "coordinateFrame", "snapPoints"],
  "properties": {
    "partId": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "unit": { "type": "string", "enum": ["LDU"] },
    "coordinateFrame": { "type": "string", "enum": ["part-local"] },
    "snapPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "position", "normal"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["stud-top", "stud-bottom"] },
          "position": {
            "type": "array",
            "items": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3,
            "additionalItems": false
          },
          "normal": {
            "type": "array",
            "items": [
              { "type": "number" },
              { "type": "number" },
              { "type": "number" }
            ],
            "minItems": 3,
            "maxItems": 3,
            "additionalItems": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}